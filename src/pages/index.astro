---
import Layout from "../components/layout/Layout.astro";
import ButtonSwitchTheme from "../components/user-interface/ButtonSwitchTheme.astro";
import Profile from "../components/layout/Profile.astro";
import Portfolio from "../components/layout/Portfolio";
import Footer from "../components/user-interface/Footer.astro";

const title: string = 'Inicio';
const description: string = 'Texto de borrador';
---

<Layout title={title} description={description}>
    <ButtonSwitchTheme/>
    <Profile/>
    <Portfolio client:load/>
    <Footer/>
</Layout>